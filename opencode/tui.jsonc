{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "catppuccin-macchiato-transparent",
  "scroll_speed": 3,
  // OpenCode 1.14.41 rejects keymap blocks at startup, despite the published schema.
  "keybinds": {
    "leader": "ctrl+o",
    "app_exit": "ctrl+c,<leader>q",
    "messages_half_page_up": "ctrl+u,ctrl+alt+u",
    "messages_half_page_down": "ctrl+d,ctrl+alt+d",
    "input_delete": "delete,shift+delete",
    "input_delete_to_line_end": "none",
    "input_delete_to_line_start": "none"
  },
  "scroll_acceleration": {
    "enabled": true
  }
}
