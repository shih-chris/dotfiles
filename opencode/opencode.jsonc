{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "default_agent": "build",
  "agent": {
    "build": {
      "mode": "primary",
      "model": "openai/gpt-5.3-codex"
    },
    "plan": {
      "mode": "primary",
      "model": "anthropic/claude-opus-4-5"
    }
  },
  "mcp": {
    "bigquery": {
      "type": "local",
      "command": [
        "/Users/chris/Documents/mcp_servers/mcp-toolbox/toolbox",
        "--prebuilt",
        "bigquery",
        "--stdio"
      ],
      "enabled": true,
      "environment": {
        "BIGQUERY_PROJECT": "grafanalabs-global"
      }
    }
  }
}
