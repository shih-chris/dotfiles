{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "default_agent": "build",
  "agent": {
    "build": {
      "mode": "primary",
      "model": "openai/gpt-5.3-codex"
    },
    "plan": {
      "mode": "primary",
      "model": "anthropic/claude-opus-4-7",
      "variant": "max"
    }
  },
  "mcp": {
    "bigquery": {
      "type": "local",
      "command": [
        "/Users/chris/Documents/mcp_servers/mcp-toolbox/toolbox",
        "--prebuilt",
        "bigquery",
        "--stdio"
      ],
      "enabled": false,
      "environment": {
        "BIGQUERY_PROJECT": "grafanalabs-global"
      }
    },
    "airbud": {
      "type": "remote",
      "url": "https://airbud-mcp-prod-1000862261726.us-central1.run.app/mcp",
      "enabled": true
    }
  }
}
